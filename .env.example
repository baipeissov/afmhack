NEXT_PUBLIC_API_URL=http://localhost:8000
API_URL=http://localhost:8000

# LLM via OpenRouter (https://openrouter.ai). Free models are used by default.
OPENROUTER_API_KEY=

# Engagement (investigator) agent. Real outbound messaging stays OFF unless true.
# When false, the agent runs in simulation mode (LLM role-plays the fraudster).
ENGAGEMENT_LIVE=false

# Optional third-party scraping fallback (e.g. apify / rapidapi). Leave blank to disable.
SCRAPER_API_PROVIDER=
SCRAPER_API_KEY=
